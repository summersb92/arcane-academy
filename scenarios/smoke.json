{
  "name": "smoke",
  "seed": 1,
  "steps": [
    { "note": "fresh game starts penniless" },
    { "assert": { "path": "run.resources.gold", "op": "==", "value": 0 } },
    { "note": "Clean Stables (instant): stamina 1 -> gold 2.5" },
    { "do": "clean-stables" },
    { "assert": { "path": "run.resources.gold", "op": ">=", "value": 2.5 } },
    { "sim": 60 },
    { "assert": { "path": "playtime", "op": ">=", "value": 60 } }
  ]
}
