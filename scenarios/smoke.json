{
  "name": "smoke",
  "seed": 1,
  "steps": [
    { "note": "fresh game starts penniless" },
    { "assert": { "path": "run.resources.gold", "op": "==", "value": 0 } },
    { "note": "Clean Stables (instant): stamina 1 -> gold 0.25 (v0.1.1)" },
    { "do": "clean-stables" },
    { "assert": { "path": "run.resources.gold", "op": ">=", "value": 0.25 } },
    { "sim": 60 },
    { "assert": { "path": "playtime", "op": ">=", "value": 60 } }
  ]
}
